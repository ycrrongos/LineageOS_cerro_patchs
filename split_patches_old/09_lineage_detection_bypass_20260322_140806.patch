+            case "org.lineageos.jelly":
+            case "org.lineageos.aperture":
+            case "org.lineageos.recorder":
+            case "org.lineageos.etar":
+            case "org.lineageos.twelve":
+            case "org.lineageos.glimpse":
+            case "org.lineageos.lineageparts":
+            case "org.lineageos.profiles":
+            case "org.lineageos.backgrounds":
+            case "org.lineageos.camelot":
+            case "org.lineageos.lineagesettings":
+            case "org.lineageos.setupwizard":
+            case "org.lineageos.audiofx":
+            case "org.lineageos.overlay.customization.blacktheme":
+            case "lineageos.platform":
+            case "lineageos.platform.overlay.xiaomi":
+            case "org.lineageos.aperture.frameworksbaseoverlay":
+            case "org.lineageos.aperture.overlay.marble":
+            case "org.lineageos.glimpse.frameworksbaseoverlay":
+            case "org.lineageos.overlay.font.googlesansflex":
+            case "org.lineageos.qtitelephony.compat":
+            case "org.lineageos.settingsconfig":
+            case "co.aospa.sense":
+            case "org.protonaosp.deviceconfig":
+                return true;
+            default:
+                return false;
+        }
+    }
+
+    private ArraySet<String> getLineageVisibilityBlockedPackages(@UserIdInt int userId) {
+        final String value = android.provider.Settings.Secure.getStringForUser(
+                mContext.getContentResolver(),
+                LINEAGE_VISIBILITY_BLOCKED_PACKAGES_SETTING,
+                userId);
+        final ArraySet<String> blockedPackages = new ArraySet<>();
+        if (TextUtils.isEmpty(value)) {
+            return blockedPackages;
+        }
+        final String[] packageNames = value.split(",");
+        for (int i = 0; i < packageNames.length; i++) {
+            final String packageName = packageNames[i].trim();
+            if (!packageName.isEmpty()) {
+                blockedPackages.add(packageName);
+            }
+        }
+        return blockedPackages;
+    }
