+    private boolean shouldFilterLineageTargetPackage(@Nullable PackageStateInternal targetPs,
+            int callingUid, @Nullable SettingBase callingPs, @UserIdInt int userId) {
+        if (targetPs == null) {
+            return false;
+        }
+        if (!isLineageVisibilityTargetPackage(targetPs.getPackageName())) {
+            return false;
+        }
+        if (isSystemOrRootOrShell(callingUid) || callingPs == null) {
+            return false;
+        }
+        final ArraySet<String> blockedPackages = getLineageVisibilityBlockedPackages(userId);
+        if (blockedPackages.isEmpty()) {
+            return false;
+        }
+        if (callingPs instanceof PackageSetting) {
+            return blockedPackages.contains(((PackageSetting) callingPs).getPackageName());
+        }
+        if (callingPs instanceof SharedUserSetting) {
+            final ArraySet<PackageStateInternal> packageStates =
+                    (ArraySet<PackageStateInternal>) ((SharedUserSetting) callingPs)
+                            .getPackageStates();
+            for (int i = packageStates.size() - 1; i >= 0; i--) {
+                if (blockedPackages.contains(packageStates.valueAt(i).getPackageName())) {
+                    return true;
+                }
+            }
+        }
+        return false;
+    }
