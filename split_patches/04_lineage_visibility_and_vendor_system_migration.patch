+package com.android.settings.spa.app.appinfo
+
+import android.content.Context
+import android.content.pm.ApplicationInfo
+import android.os.Process
+import android.provider.Settings
+import androidx.compose.runtime.Composable
+import androidx.compose.runtime.remember
+import androidx.compose.ui.platform.LocalContext
+import androidx.lifecycle.compose.collectAsStateWithLifecycle
+import com.android.settings.R
+import com.android.settingslib.spa.widget.preference.SwitchPreference
+import com.android.settingslib.spa.widget.preference.SwitchPreferenceModel
+import com.android.settingslib.spaprivileged.model.app.userId
+import kotlinx.coroutines.flow.MutableStateFlow
+
+private const val LINEAGE_VISIBILITY_BLOCKED_PACKAGES_SETTING =
+    "lineage_visibility_blocked_packages"
+private const val LINEAGE_TARGET_PACKAGE = "org.lineageos.updater"
+
+@Composable
+fun LineageAppVisibilityBlockSwitchPreference(app: ApplicationInfo) {
+    val context = LocalContext.current
+    val presenter = remember(app) { LineageAppVisibilityBlockPresenter(context, app) }
+    if (!presenter.isAvailable()) return
+
+    val isCheckedState = presenter.isCheckedFlow.collectAsStateWithLifecycle()
+    SwitchPreference(remember {
+        object : SwitchPreferenceModel {
+            override val title = context.getString(R.string.lineage_visibility_block_title)
+            override val summary = {
+                context.getString(R.string.lineage_visibility_block_summary)
+            }
+            override val checked = { isCheckedState.value }
+            override val onCheckedChange = presenter::onCheckedChange
+        }
+    })
+}
+
+private class LineageAppVisibilityBlockPresenter(
+    private val context: Context,
+    private val app: ApplicationInfo,
+) {
+    private val isChecked = MutableStateFlow(readBlockedPackages().contains(app.packageName))
+    val isCheckedFlow = isChecked
+
+    fun isAvailable(): Boolean {
+        if (app.packageName == LINEAGE_TARGET_PACKAGE) return false
+        if (app.uid < Process.FIRST_APPLICATION_UID) return false
+        if ((app.flags and ApplicationInfo.FLAG_SYSTEM) != 0) return false
+        if ((app.flags and ApplicationInfo.FLAG_UPDATED_SYSTEM_APP) != 0) return false
+        return true
+    }
+
+    fun onCheckedChange(newChecked: Boolean) {
+        val blockedPackages = readBlockedPackages().toMutableSet()
+        if (newChecked) {
+            blockedPackages.add(app.packageName)
+        } else {
+            blockedPackages.remove(app.packageName)
+        }
+        if (writeBlockedPackages(blockedPackages)) {
+            isChecked.value = newChecked
+        }
+    }
+
+    private fun readBlockedPackages(): Set<String> {
+        val value =
+            Settings.Secure.getStringForUser(
+                context.contentResolver,
+                LINEAGE_VISIBILITY_BLOCKED_PACKAGES_SETTING,
+                app.userId,
+            ) ?: return emptySet()
+        return value.split(',').mapNotNull { item ->
+            val trimmed = item.trim()
+            if (trimmed.isEmpty()) null else trimmed
+        }.toSet()
+    }
+
+    private fun writeBlockedPackages(packages: Set<String>): Boolean {
+        val value = packages.sorted().joinToString(",")
+        return runCatching {
+            Settings.Secure.putStringForUser(
+                context.contentResolver,
+                LINEAGE_VISIBILITY_BLOCKED_PACKAGES_SETTING,
+                if (value.isEmpty()) null else value,
+                app.userId,
+            )
+        }.getOrDefault(false)
+    }
+}


