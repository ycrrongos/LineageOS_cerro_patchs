+                TaskContainer taskContainer, boolean isLocked) {
+            super(R.drawable.ic_lock,
+                    isLocked ? R.string.recent_task_option_unlock
+                            : R.string.recent_task_option_lock,
+                    target, taskContainer.getItemInfo(), taskContainer.getTaskView());
+            mTaskContainer = taskContainer;
+            mIsLocked = isLocked;
+        }
+
+        @Override
+        public void onClick(View view) {
+            RecentsView recentsView = mTaskContainer.getTaskView().getRecentsView();
+            if (recentsView != null) {
+                recentsView.setTaskLocked(mTaskContainer.getTask(), !mIsLocked);
