+        }
+        return bssl::UniquePtr<EVP_PKEY>(PEM_read_bio_PrivateKey(bio.get(), nullptr, nullptr, nullptr));
+    }
+
+    const uint8_t* p = key_buf;
+    return bssl::UniquePtr<EVP_PKEY>(d2i_AutoPrivateKey(nullptr, &p, static_cast<long>(key_len)));
+}
