+
+    std::string_view key_view(reinterpret_cast<const char*>(key_buf), key_len);
+    bool looks_pem = key_view.find("-----BEGIN") != std::string_view::npos;
+    if (looks_pem) {
+        bssl::UniquePtr<BIO> bio(BIO_new_mem_buf(key_buf, static_cast<int>(key_len)));
+        if (!bio) {
