+    // Safety: verifyCertificateSignedBy only reads the provided buffers.
+    unsafe {
+        verifyCertificateSignedBy(
+            child_cert_buf.as_ptr(),
+            child_cert_buf.len(),
+            parent_cert_buf.as_ptr(),
