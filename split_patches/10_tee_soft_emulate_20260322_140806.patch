+    if (issuer_len > issuer_buf_len) {
+        ALOGI("extractIssuerFromCertificate: needed %d bytes for issuer, caller provided %zu",
+              issuer_len, issuer_buf_len);
+        return -issuer_len;
+    }
+
+    uint8_t* tmp = issuer_buf;
+    return i2d_X509_NAME(issuer, &tmp);
