+        @Override // Binder call
+        public void setBrightnessRampRate(int rate) {
+            if (!mSystemReady || mDisplayManagerInternal == null) {
+                return;
+            }
+
+            final int callingUid = Binder.getCallingUid();
+            if (!isAllowedLegacyBrightnessRampCaller(callingUid)) {
+                Slog.w(TAG, "Ignoring setBrightnessRampRate from uid=" + callingUid);
+                return;
+            }
+
+            final long ident = Binder.clearCallingIdentity();
+            try {
+                mDisplayManagerInternal.setBrightnessRampRateOverride(Display.DEFAULT_DISPLAY,
+                        rate);
+            } finally {
+                Binder.restoreCallingIdentity(ident);
+            }
+        }
+
+        private boolean isAllowedLegacyBrightnessRampCaller(int callingUid) {
+            if (callingUid == Process.SYSTEM_UID
+                    || callingUid == Process.ROOT_UID
+                    || callingUid == Process.SHELL_UID) {
+                return true;
+            }
+
+            final String[] packages = mContext.getPackageManager().getPackagesForUid(callingUid);
+            if (packages == null) {
+                return false;
+            }
+            for (String packageName : packages) {
+                if (LEGACY_CAMERA_PACKAGE.equals(packageName)) {
+                    return true;
+                }
+            }
+            return false;
+        }
