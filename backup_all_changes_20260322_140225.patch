+        .as_deref()
+        .map(str::trim)
+        .map(str::to_ascii_lowercase)
+        .as_deref()
+    {
+        Some("generate") => TeeSoftDebugMode::Generate,
+        Some("auto") => TeeSoftDebugMode::Auto,
+        _ => TeeSoftDebugMode::Patch,
+    }
