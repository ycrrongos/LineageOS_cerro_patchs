+    // Safety: getCertificatePublicKeyFamily only reads the provided buffer.
+    match unsafe { getCertificatePublicKeyFamily(cert_buf.as_ptr(), cert_buf.len()) } {
+        1 => Some("rsa"),
+        2 => Some("ec"),
+        _ => None,
+    }
