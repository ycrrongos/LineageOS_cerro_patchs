+                        return !mTrustManager.isInSignificantPlace();
+                    } catch (RemoteException e) {
+                        Slog.e(TAG, "Remote exception while trying to check "
+                                + "if user is in a trusted location.");
+                    }
+                }
+                return true;
+            }
+            return false;
+        }
