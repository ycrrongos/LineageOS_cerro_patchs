+
+        if (!isIncremental) {
+            viewHolder.mWhatsNew.setVisibility(View.GONE);
+            viewHolder.mWhatsNew.setText(null);
+            return;
+        }
+
+        viewHolder.mWhatsNew.setVisibility(View.VISIBLE);
+        String whatsNew = update.getWhatsNew();
+        if (hasText(whatsNew)) {
+            viewHolder.mWhatsNew.setText(whatsNew);
+        } else {
+            viewHolder.mWhatsNew.setText(R.string.update_whatsnew_loading);
+            maybeFetchWhatsNew(update, downloadId);
+        }
+    }
