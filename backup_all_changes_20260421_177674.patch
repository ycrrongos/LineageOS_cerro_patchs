+    private static boolean hasText(String text) {
+        return !TextUtils.isEmpty(text) && !TextUtils.isEmpty(text.trim());
+    }
+
+    private String downloadWhatsNew(String urlString) {
+        HttpURLConnection connection = null;
+        try {
+            connection = (HttpURLConnection) new URL(urlString).openConnection();
+            connection.setConnectTimeout(5000);
+            connection.setReadTimeout(5000);
+            connection.setRequestMethod("GET");
+
+            if (connection.getResponseCode() != HttpURLConnection.HTTP_OK) {
+                Log.w(TAG, "Could not download what's new file, response=" + connection.getResponseCode());
+                return null;
+            }
+
+            StringBuilder builder = new StringBuilder();
+            try (BufferedReader reader = new BufferedReader(
+                    new InputStreamReader(connection.getInputStream(), StandardCharsets.UTF_8))) {
+                for (String line; (line = reader.readLine()) != null; ) {
+                    if (builder.length() > 0) {
+                        builder.append('\n');
+                    }
+                    builder.append(line);
+                }
+            }
+            String text = builder.toString().trim();
+            return text.isEmpty() ? null : text;
+        } catch (IOException e) {
+            Log.w(TAG, "Could not fetch what's new from " + urlString, e);
+            return null;
+        } finally {
+            if (connection != null) {
+                connection.disconnect();
+            }
+        }
+    }
+
+    private void maybeFetchWhatsNew(UpdateInfo update, String downloadId) {
+        long minBaseTimestamp = update.getMinBaseTimestamp();
+        if (minBaseTimestamp <= 0 || hasText(update.getWhatsNew()) || !mFetchingWhatsNew.add(downloadId)) {
+            return;
+        }
+
+        String url = Utils.getWhatsNewURL(minBaseTimestamp);
+        if (url == null) {
+            mFetchingWhatsNew.remove(downloadId);
+            return;
+        }
+
+        mWhatsNewExecutor.execute(() -> {
+            String whatsNew = downloadWhatsNew(url);
+            if (!hasText(whatsNew)) {
+                whatsNew = mActivity.getString(R.string.update_whatsnew_unavailable);
+            }
+
+            final String resolvedWhatsNew = whatsNew;
+            mActivity.runOnUiThread(() -> {
+                UpdateInfo current = mUpdaterController == null ? null : mUpdaterController.getUpdate(downloadId);
+                if (current instanceof Update) {
+                    ((Update) current).setWhatsNew(resolvedWhatsNew);
+                    notifyItemChanged(downloadId);
+                }
+                mFetchingWhatsNew.remove(downloadId);
+            });
+        });
+    }
+
+    private void bindTypeAndWhatsNew(ViewHolder viewHolder, UpdateInfo update, String downloadId) {
+        boolean isIncremental = update.getMinBaseTimestamp() > 0;
