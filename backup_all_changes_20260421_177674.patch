+private const val LINEAGE_PLAY_STORE_INSTALL_SPOOF_PACKAGES_SETTING =
+    "lineage_play_store_install_spoof_packages"
+private const val LINEAGE_TARGET_PACKAGE = "org.lineageos.updater"
+
+@Composable
+fun PlayStoreInstallSpoofSwitchPreference(app: ApplicationInfo) {
+    val context = LocalContext.current
+    val presenter = remember(app) { PlayStoreInstallSpoofPresenter(context, app) }
+    if (!presenter.isAvailable()) return
+
+    val isCheckedState = presenter.isCheckedFlow.collectAsStateWithLifecycle()
+    SwitchPreference(remember {
+        object : SwitchPreferenceModel {
+            override val title = context.getString(R.string.play_store_install_spoof_title)
+            override val summary = {
+                context.getString(R.string.play_store_install_spoof_summary)
+            }
+            override val checked = { isCheckedState.value }
+            override val onCheckedChange = presenter::onCheckedChange
+        }
+    })
+}
+
+private class PlayStoreInstallSpoofPresenter(
+    private val context: Context,
+    private val app: ApplicationInfo,
+) {
+    private val isChecked = MutableStateFlow(readPackages().contains(app.packageName))
+    val isCheckedFlow = isChecked
+
+    fun isAvailable(): Boolean {
+        if (app.packageName == LINEAGE_TARGET_PACKAGE) return false
+        if (app.uid < Process.FIRST_APPLICATION_UID) return false
+        if ((app.flags and ApplicationInfo.FLAG_SYSTEM) != 0) return false
+        if ((app.flags and ApplicationInfo.FLAG_UPDATED_SYSTEM_APP) != 0) return false
+        return true
+    }
+
+    fun onCheckedChange(newChecked: Boolean) {
+        val packages = readPackages().toMutableSet()
+        if (newChecked) {
+            packages.add(app.packageName)
+        } else {
+            packages.remove(app.packageName)
+        }
+        if (writePackages(packages)) {
+            isChecked.value = newChecked
+        }
+    }
+
+    private fun readPackages(): Set<String> {
+        val value =
+            Settings.Secure.getStringForUser(
+                context.contentResolver,
+                LINEAGE_PLAY_STORE_INSTALL_SPOOF_PACKAGES_SETTING,
+                app.userId,
+            ) ?: return emptySet()
+        return value.split(',').mapNotNull { item ->
+            val trimmed = item.trim()
+            if (trimmed.isEmpty()) null else trimmed
+        }.toSet()
+    }
+
+    private fun writePackages(packages: Set<String>): Boolean {
+        val value = packages.sorted().joinToString(",")
+        return runCatching {
+            Settings.Secure.putStringForUser(
+                context.contentResolver,
+                LINEAGE_PLAY_STORE_INSTALL_SPOOF_PACKAGES_SETTING,
+                if (value.isEmpty()) null else value,
+                app.userId,
+            )
+        }.getOrDefault(false)
+    }
+}

