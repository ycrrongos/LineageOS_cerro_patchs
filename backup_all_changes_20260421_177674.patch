@@ -0,0 +1,9 @@
+# Keep selected /system_ext/priv-app Lineage packages out of untrusted app reach.
+allow system_server lineage_privapp_pkg_file:dir r_dir_perms;
+allow system_server lineage_privapp_pkg_file:file r_file_perms;
+allow system_server lineage_privapp_pkg_file:lnk_file r_file_perms;
+
+# Trusted app domains that may still need visibility.
+allow { platform_app system_app priv_app } lineage_privapp_pkg_file:dir r_dir_perms;
+allow { platform_app system_app priv_app } lineage_privapp_pkg_file:file r_file_perms;
+allow { platform_app system_app priv_app } lineage_privapp_pkg_file:lnk_file r_file_perms;

